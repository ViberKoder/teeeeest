# Network the wallet operates on: 'mainnet' (default) or 'testnet'.
VITE_TON_NETWORK=mainnet

# Optional Toncenter v2 API key for higher RPC limits (sendBoc, get-methods).
# VITE_TONCENTER_API_KEY=

# Optional TonAPI endpoint override + bearer token.
# VITE_TONAPI_BASE=https://tonapi.io
# VITE_TONAPI_TOKEN=

# Optional pre-filled RMJ jetton master shown in "Add jetton" lookup.
# VITE_DEFAULT_RMJ_MASTER=EQ...
# VITE_DEFAULT_RMJ_BACKEND=https://your-rmj-backend.example.com

# UI name (default "RMJ Wallet").
# VITE_APP_NAME=Tap Wallet
