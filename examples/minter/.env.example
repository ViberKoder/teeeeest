# Опционально: свой URL manifest (если не задан — грузится /tonconnect-manifest.json с этого же домена)
# VITE_TONCONNECT_MANIFEST_URL=https://example.com/tonconnect-manifest.json

# Для Vercel со своим доменом: канонический https origin (без / в конце), иначе url в manifest может не совпасть с вкладкой
# VITE_APP_ORIGIN=https://your-custom-domain.com

# testnet | mainnet (должен совпадать со скомпилированными BOC в src/constants.ts)
VITE_NETWORK=testnet
