# RMJ backend (optional — enables off-chain balance + claim for configured master)
# VITE_RMJ_BACKEND_URL=https://your-backend.up.railway.app
# VITE_JETTON_MASTER_ADDRESS=EQ…

# TonAPI key (optional — raises rate limits; works without key on public tier)
# VITE_TONAPI_KEY=

# testnet | mainnet
VITE_TON_NETWORK=mainnet

# Custom manifest origin for TON Connect (defaults to same origin)
# VITE_TONCONNECT_MANIFEST_URL=https://wallet.example.com/tonconnect-manifest.json
# VITE_APP_ORIGIN=https://wallet.example.com
