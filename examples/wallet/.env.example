# RMJ backend (optional — off-chain balance + claim for configured master)
# VITE_RMJ_BACKEND_URL=https://your-backend.up.railway.app
# VITE_JETTON_MASTER_ADDRESS=EQ…

# TonAPI key (optional — higher rate limits for balances/NFTs)
# VITE_TONAPI_KEY=

# TON RPC for sending transactions (defaults to toncenter)
# VITE_TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
# VITE_TON_RPC_API_KEY=

# testnet | mainnet
VITE_TON_NETWORK=mainnet
