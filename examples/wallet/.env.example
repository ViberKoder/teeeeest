# RMJ backend (optional — off-chain balance + Merkle proof for configured master)
# NEXT_PUBLIC_RMJ_BACKEND_URL=https://your-backend.up.railway.app
# NEXT_PUBLIC_JETTON_MASTER_ADDRESS=EQ…

# TonAPI key (optional — higher rate limits for balances/NFTs)
# NEXT_PUBLIC_TONAPI_KEY=

# TON RPC for sending transactions (defaults to toncenter)
# NEXT_PUBLIC_TON_RPC_ENDPOINT=https://toncenter.com/api/v2/jsonRPC
# NEXT_PUBLIC_TON_RPC_API_KEY=

# testnet | mainnet
NEXT_PUBLIC_TON_NETWORK=mainnet
