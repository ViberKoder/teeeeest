# Telegram bot token from @BotFather
TELEGRAM_BOT_TOKEN=123456:AAAAAAAA

# RMJ backend URL
RMJ_BACKEND_URL=http://localhost:3000

# Admin secret for this bot to call /api/v1/action (same as backend ADMIN_JWT_SECRET
# if you want to bypass rate-limits for service-to-service calls; leave empty to
# use public rate-limits).
RMJ_ADMIN_SECRET=

# How many nano-jettons each click awards (default: inherited from backend)
# Leave empty to use the backend default.
REWARD_PER_CLICK_NANO=1000000000

# Bot welcome message branding
PROJECT_NAME=TapCoin
