{
  "name": "rolling-mintless-jetton",
  "version": "0.1.0",
  "private": true,
  "description": "Rolling Mintless Jetton - growing-balance on-chain token system for TON games, bots and mini-apps",
  "license": "MIT",
  "workspaces": [
    "contracts",
    "backend",
    "sdk",
    "examples/telegram-bot",
    "examples/tma",
    "examples/minter"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "npm run test --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "backend:dev": "npm run dev -w @rmj/backend",
    "backend:build": "npm run build -w @rmj/backend",
    "backend:start": "npm run start -w @rmj/backend",
    "backend:start:tsx": "npm run start:tsx -w @rmj/backend"
  }
}
