{
  "name": "@rmj/contracts",
  "version": "0.1.0",
  "private": true,
  "description": "FunC smart contracts + TS wrappers + sandbox tests for Rolling Mintless Jetton",
  "main": "wrappers/index.ts",
  "types": "wrappers/index.ts",
  "files": [
    "contracts/",
    "wrappers/",
    "build/"
  ],
  "scripts": {
    "build": "ts-node scripts/exportBocs.ts",
    "test": "jest --runInBand",
    "start": "blueprint run",
    "deploy": "ts-node scripts/deploy.ts",
    "deploy:testnet": "TON_NETWORK=testnet ts-node scripts/deploy.ts",
    "deploy:mainnet": "TON_NETWORK=mainnet ts-node scripts/deploy.ts"
  },
  "dependencies": {
    "@ton/blueprint": "^0.27.0",
    "@ton/core": "^0.62.0",
    "@ton/crypto": "^3.3.0",
    "@ton/ton": "^15.4.0"
  },
  "devDependencies": {
    "@ton/sandbox": "^0.27.0",
    "@ton/test-utils": "^0.4.2",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
