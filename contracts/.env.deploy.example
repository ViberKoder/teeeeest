### RMJ deploy config
### copy to contracts/.env and edit

# testnet | mainnet
NETWORK=testnet

# Optional override. If empty:
# - testnet => https://testnet.toncenter.com/api/v2/jsonRPC
# - mainnet => https://toncenter.com/api/v2/jsonRPC
TON_RPC_ENDPOINT=
TON_API_KEY=

# 24-word admin wallet mnemonic (this wallet becomes Jetton admin)
ADMIN_MNEMONIC="word1 word2 ... word24"

# 32-byte signer seed in hex (64 symbols). Used to derive signer pubkey.
SIGNER_SEED_HEX=1111111111111111111111111111111111111111111111111111111111111111

# Optional explicit signer pubkey hex (64 chars).
# If empty, pubkey is derived from SIGNER_SEED_HEX.
SIGNER_PUBKEY_HEX=

# Off-chain metadata URL (TEP-64)
METADATA_URL=https://example.com/jetton-metadata.json

# TON for master deploy tx
DEPLOY_TON=0.2

# Optional initial mint after deploy
INITIAL_MINT_AMOUNT_NANO=0
# Recipient of initial mint (defaults to admin wallet if empty)
INITIAL_MINT_TO=
# TON to attach into mint path (master->wallet internal value)
INITIAL_MINT_TON=0.1
